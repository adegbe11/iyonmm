{
  "manifest_version": 3,
  "name": "Erasa Data Removal Assistant",
  "version": "1.0.0",
  "description": "Automatically opens every data broker opt-out page, fills in your details, and submits where it is safe. Your data never leaves your browser.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "*://*.spokeo.com/*", "*://*.whitepages.com/*", "*://*.beenverified.com/*",
    "*://*.truepeoplesearch.com/*", "*://*.fastpeoplesearch.com/*", "*://*.radaris.com/*",
    "*://*.peopleconnect.us/*", "*://*.mylife.com/*", "*://*.familytreenow.com/*",
    "*://*.nationalpublicdata.com/*", "*://*.peoplefinders.com/*", "*://*.ussearch.com/*",
    "*://*.nuwber.com/*", "*://*.usphonebook.com/*", "*://*.checkpeople.com/*",
    "*://*.peoplelooker.com/*", "*://*.advancedbackgroundchecks.com/*", "*://*.searchpeoplefree.com/*",
    "*://*.anywho.com/*", "*://*.intelius.com/*", "*://*.peekyou.com/*",
    "*://*.socialcatfish.com/*", "*://*.clustrmaps.com/*", "*://*.rocketreach.co/*",
    "*://*.apollo.io/*", "*://apolloio.zendesk.com/*", "*://*.lexisnexis.com/*",
    "*://*.acxiom.com/*", "*://*.epsilon.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Erasa Data Removal" },
  "content_scripts": [
    {
      "matches": [
        "*://*.spokeo.com/*", "*://*.whitepages.com/*", "*://*.beenverified.com/*",
        "*://*.truepeoplesearch.com/*", "*://*.fastpeoplesearch.com/*", "*://*.radaris.com/*",
        "*://*.peopleconnect.us/*", "*://*.mylife.com/*", "*://*.familytreenow.com/*",
        "*://*.nationalpublicdata.com/*", "*://*.peoplefinders.com/*", "*://*.ussearch.com/*",
        "*://*.nuwber.com/*", "*://*.usphonebook.com/*", "*://*.checkpeople.com/*",
        "*://*.peoplelooker.com/*", "*://*.advancedbackgroundchecks.com/*", "*://*.searchpeoplefree.com/*",
        "*://*.anywho.com/*", "*://*.intelius.com/*", "*://*.peekyou.com/*",
        "*://*.socialcatfish.com/*", "*://*.clustrmaps.com/*", "*://*.rocketreach.co/*",
        "*://*.apollo.io/*", "*://apolloio.zendesk.com/*", "*://*.lexisnexis.com/*",
        "*://*.acxiom.com/*", "*://*.epsilon.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
